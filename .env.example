# ========================== JARVIS Bot — Variables de Entorno ==========================
# Copia este archivo como .env y rellena los valores

# Token del bot de Discord (OBLIGATORIO)
DISCORD_TOKEN=tu_token_aqui

# API Key de Gemini (OPCIONAL - para conversaciones con IA)
# Obtener en: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Puerto para Flask (Render lo asigna automáticamente)
PORT=10000
